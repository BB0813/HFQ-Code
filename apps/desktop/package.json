{
  "name": "@hfq/desktop",
  "version": "1.1.9",
  "private": true,
  "description": "HFQ Code desktop shell",
  "main": "electron/main.cjs",
  "author": "HFQ",
  "scripts": {
    "dev": "vite --config renderer/vite.config.ts",
    "dev:electron": "electron electron/main.cjs",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "start": "pnpm run build:renderer && electron electron/main.cjs",
    "typecheck": "tsc -p renderer/tsconfig.json --noEmit",
    "build": "pnpm run build:renderer",
    "prepack:dir": "pnpm run build:renderer",
    "prepack:win": "pnpm run build:renderer",
    "prepack:portable": "pnpm run build:renderer",
    "pack:dir": "electron-builder --win dir --x64 --publish never",
    "pack:win": "electron-builder --win nsis portable --x64 --publish never",
    "pack:portable": "electron-builder --win portable --x64 --publish never"
  },
  "dependencies": {
    "@hfq/agent-core": "workspace:*",
    "@hfq/config": "workspace:*",
    "@hfq/mcp": "workspace:*",
    "@hfq/memory": "workspace:*",
    "@hfq/policy": "workspace:*",
    "@hfq/providers": "workspace:*",
    "@hfq/pty": "workspace:*",
    "@hfq/session-api": "workspace:*",
    "@hfq/shared": "workspace:*",
    "@hfq/skills": "workspace:*",
    "@hfq/tools": "workspace:*",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.24.0",
    "mermaid": "11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "35.7.5",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.hfq.code",
    "productName": "HFQ Code",
    "copyright": "Copyright © HFQ",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "electronDist": "node_modules/electron/dist",
    "icon": "build/icon.ico",
    "afterPack": "../../scripts/after-pack.mjs",
    "afterAllArtifactBuild": "../../scripts/windows-sign.mjs",
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "asar": false,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "publish": null,
    "extraResources": [
      {
        "from": "../../skills/bundled",
        "to": "skills/bundled",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/trust",
        "to": "trust",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/Launch-HFQ-Code.bat",
        "to": "Launch-HFQ-Code.bat"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HFQ Code",
      "include": "installer-trust.nsh",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
