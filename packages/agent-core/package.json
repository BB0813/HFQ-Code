{
  "name": "@hfq/agent-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./worker": {
      "types": "./dist/worker/entry.d.ts",
      "import": "./dist/worker/entry.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hfq/mcp": "workspace:*",
    "@hfq/memory": "workspace:*",
    "@hfq/policy": "workspace:*",
    "@hfq/providers": "workspace:*",
    "@hfq/shared": "workspace:*",
    "@hfq/skills": "workspace:*",
    "@hfq/tools": "workspace:*",
    "@hfq/transcript": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
